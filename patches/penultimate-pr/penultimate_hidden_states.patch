+            ggml_backend_t backend_pen = ggml_backend_sched_get_tensor_backend(sched.get(), t_embd_pen);
+            GGML_ASSERT(backend_pen != nullptr);
+            const uint32_t n_embd_dim = hparams.n_embd;
